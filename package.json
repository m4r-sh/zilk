{
  "version": "0.0.5",
  "name": "zilk",
  "description": "lightweight and flexible web framework",
  "author": {
    "name": "m4rsh",
    "email": "me@m4r.sh",
    "url": "https://m4r.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/m4r-sh/zilk.git"
  },
  "scripts": {
    "build": "bun ./scripts/build.js",
    "dev": "bun --watch ./scripts/build.js"
  },
  "type": "module",
  "exports": {
    ".": {
      "bun": "./build/ssr/bun.js",
      "node": "./build/ssr/node.js",
      "worker": "./build/ssr/node.js",
      "browser": "./build/index.min.js",
      "import": "./build/index.js",
      "require": "./build/index.js"
    },
    "./hydrate": {
      "browser": "./build/hydrate/index.js",
      "import": "./build/hydrate/index.js"
    },
    "./router": {
      "browser": "./build/router/index.js",
      "import": "./build/router/index.js"
    }
  },
  "dependencies": {
    "orbz": "^0.1.0",
    "regexparam": "^2.0.1",
    "uhtml": "^4.4.7",
    "uhtml-ssr": "^0.9.1",
    "wicked-elements": "^3.1.2"
  }
}
